{
  "dfx": "0.30.2",
  "canisters": {
    "tinypress": {
      "type": "rust",
      "candid": "tinypress.did",
      "package": "tinypress"
    },
    "tinypress_frontend": {
      "type": "assets",
      "source": [
        "src/frontend/dist"
      ],
      "build": [
        "npm --prefix src/frontend install",
        "npm --prefix src/frontend run build"
      ],
      "dependencies": [
        "tinypress"
      ]
    }
  },
  "defaults": {
    "build": {
      "args": "",
      "packtool": ""
    }
  },
  "version": 1
}
