{
  "dfx": "0.30.2",
  "canisters": {
    "tinypress": {
      "type": "rust",
      "candid": "tinypress.did",
      "package": "tinypress"
    },
    "internet_identity": {
      "type": "custom",
      "candid": "https://github.com/dfinity/internet-identity/releases/download/release-2026-03-23/internet_identity.did",
      "wasm": "https://github.com/dfinity/internet-identity/releases/download/release-2026-03-23/internet_identity_dev.wasm.gz",
      "init_arg": "(opt record { captcha_config = opt record { max_unsolved_captchas = 50 : nat64; captcha_trigger = variant { Static = variant { CaptchaDisabled } } } })",
      "remote": {
        "id": {
          "ic": "rdmx6-jaaaa-aaaaa-aaadq-cai"
        }
      },
      "frontend": {}
    },
    "tinypress_frontend": {
      "type": "assets",
      "source": [
        "src/frontend/dist"
      ],
      "build": [
        "npm --prefix src/frontend install",
        "npm --prefix src/frontend run build"
      ],
      "dependencies": [
        "tinypress"
      ]
    }
  },
  "defaults": {
    "build": {
      "args": "",
      "packtool": ""
    }
  },
  "version": 1
}
